bear-sync.example.com {
	# Rate limiting: consumers 60 req/min, bridge 120 req/min
	# Requires caddy-ratelimit plugin: https://github.com/mholt/caddy-ratelimit
	rate_limit {
		zone consumer_zone {
			match {
				path /api/*
			}
			key {remote_host}
			events 60
			window 1m
		}
		zone bridge_zone {
			match {
				path /api/sync/*
			}
			key {remote_host}
			events 120
			window 1m
		}
	}

	reverse_proxy 127.0.0.1:7433

	log {
		output file /var/log/caddy/bear-sync.log
	}
}
