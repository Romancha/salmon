# Bear Bridge Configuration
# Copy this file to ~/.config/bear-bridge/.env.bridge and fill in values.

# Hub server URL (required)
BRIDGE_HUB_URL=https://your-hub-server.example.com

# Bridge authentication token for hub (required, sync/* scope)
BRIDGE_HUB_TOKEN=your-bridge-token-here

# Bear app token for x-callback-url operations (required)
BEAR_TOKEN=your-bear-token-here

# Path to bridge state file (optional, default: ~/.bear-bridge-state.json)
# BRIDGE_STATE_PATH=

# Bear database directory (optional, default: auto-detected)
# BEAR_DB_DIR=
